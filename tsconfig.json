{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "index.ts",
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/api/**/*.ts",
    "src/auth/**/*.ts",
    "src/components/**/*.tsx",
    "src/query/query-client.ts",
    "src/screens/**/*.tsx",
    "src/services/**/*.ts",
    "src/settings/**/*.ts",
    "src/styles/theme.ts",
    "src/styles/unistyles.ts",
    "expo-env.d.ts",
    "global.d.ts",
    "react-native-web.d.ts"
  ],
  "exclude": [
    "android",
    "dist",
    "node_modules"
  ]
}
